# Razorpay — set on Vercel for Production (live keys) and locally (.env)
# Use rzp_live_* + live secret in production; rzp_test_* for local testing.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

